# I'm using a Pipeline here because it's a cleaner way to handle 
# scaling numbers and encoding categories at the same time.
from sklearn.preprocessing import OneHotEncoder, StandardScaler
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline

# Sorting columns into groups
categorical = ['promotion_type', 'location_type', 'store_size']
numerical = ['store_id', 'competition_density', 'year', 'month', 'day_of_week', 'is_weekend', 'is_festival', 'is_month_end']

# Creating the transformer
preprocessor = ColumnTransformer([
    ('cat_features', OneHotEncoder(handle_unknown='ignore'), categorical),
    ('num_features', StandardScaler(), numerical)
])
4. Model and Evaluation
Python
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error, mean_absolute_error

# Combine the preprocessing and the model into one "flow"
model_pipeline = Pipeline([
    ('prep', preprocessor),
    ('lr', LinearRegression())
])

# Training the model
model_pipeline.fit(X_train, y_train)

# Making predictions
predictions = model_pipeline.predict(X_test)

# Checking how far off the predictions are
rmse = np.sqrt(mean_squared_error(y_test, predictions))
mae = mean_absolute_error(y_test, predictions)

print(f"Average error (MAE): {mae:.2f} items")
print(f"Root Mean Square Error: {rmse:.2f}")

