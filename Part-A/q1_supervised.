import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split, GridSearchCV
from sklearn.preprocessing import StandardScaler
from sklearn.tree import DecisionTreeClassifier
from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier
from sklearn.metrics import (confusion_matrix, classification_report,
                             ConfusionMatrixDisplay, precision_score,
                             recall_score, f1_score)
sns.set_theme(style="whitegrid", palette="Set2")
print("Libraries imported!")
df = pd.read_csv("q1_heart_disease.csv")
print("Shape:", df.shape)
print("\nData Types:\n", df.dtypes)
print("\nMissing Values:\n", df.isnull().sum())
df.head()
counts = df["heart_disease"].value_counts()
plt.figure(figsize=(6, 4))
plt.bar(["No Disease (0)", "Disease (1)"], counts.values,
        color=["steelblue", "tomato"], edgecolor="black")
plt.title("Heart Disease Class Distribution")
plt.ylabel("Number of Patients")
plt.tight_layout()
plt.show()
num_cols = df.select_dtypes(include=np.number).columns.tolist()
corr = df[num_cols].corr()
plt.figure(figsize=(9, 7))
sns.heatmap(corr, annot=True, fmt=".2f", cmap="coolwarm", center=0, linewidths=0.5)
plt.title("Correlation Heatmap")
plt.tight_layout()
plt.show()
plt.figure(figsize=(8, 4))
for label, color in zip([0, 1], ["steelblue", "tomato"]):
    subset = df[df["heart_disease"] == label]["age"]
    plt.hist(subset, bins=20, alpha=0.6,
             label=f"{'Disease' if label else 'No Disease'}",
             color=color, edgecolor="black")
plt.title("Age Distribution by Heart Disease Status")
plt.xlabel("Age")
plt.ylabel("Count")
plt.legend()
plt.tight_layout()
plt.show()
df["resting_bp"]  = df["resting_bp"].fillna(df["resting_bp"].median())
df["cholesterol"] = df["cholesterol"].fillna(df["cholesterol"].median())
print("Missing after imputation:\n", df.isnull().sum())

X = df.drop("heart_disease", axis=1)
y = df["heart_disease"]

X = pd.get_dummies(X, drop_first=True)
print("Shape after encoding:", X.shape)

X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.2, stratify=y, random_state=42)
print(f"Train: {X_train.shape[0]} | Test: {X_test.shape[0]}")

scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled  = scaler.transform(X_test)
print("Scaling done!")
dt_model = DecisionTreeClassifier(random_state=42)
dt_model.fit(X_train_scaled, y_train)
print("Decision Tree - Done")

rf_model = RandomForestClassifier(random_state=42)
rf_model.fit(X_train_scaled, y_train)
print("Random Forest - Done")

gb_model = GradientBoostingClassifier(random_state=42)
gb_model.fit(X_train_scaled, y_train)
print("Gradient Boosting - Done")
models = {
    "Decision Tree":     dt_model,
    "Random Forest":     rf_model,
    "Gradient Boosting": gb_model
}

for name, model in models.items():
    y_pred = model.predict(X_test_scaled)
    print(f"\n{'='*50}\n  {name}\n{'='*50}")
    cm = confusion_matrix(y_test, y_pred)
    disp = ConfusionMatrixDisplay(cm, display_labels=["No Disease", "Disease"])
    disp.plot(cmap="Blues")
    plt.title(f"Confusion Matrix – {name}")
    plt.tight_layout()
    plt.show()
    print(classification_report(y_test, y_pred,
                                target_names=["No Disease", "Disease"]))

results = []
for name, model in models.items():
    y_pred = model.predict(X_test_scaled)
    results.append({
        "Model":     name,
        "Precision": round(precision_score(y_test, y_pred), 4),
        "Recall":    round(recall_score(y_test, y_pred), 4),
        "F1-Score":  round(f1_score(y_test, y_pred), 4),
    })
print(pd.DataFrame(results).set_index("Model").to_string())
param_grid = {
    "n_estimators":  [100, 200],
    "max_depth":     [3, 4, 5],
    "learning_rate": [0.05, 0.1]
}

grid_search = GridSearchCV(
    GradientBoostingClassifier(random_state=42),
    param_grid, cv=5, scoring="f1", n_jobs=-1, verbose=1)

grid_search.fit(X_train_scaled, y_train)
print("Best Parameters:", grid_search.best_params_)
print(f"Best CV F1-Score: {grid_search.best_score_:.4f}")

best_gb = grid_search.best_estimator_
y_pred_base  = gb_model.predict(X_test_scaled)
y_pred_tuned = best_gb.predict(X_test_scaled)

comparison = pd.DataFrame({
    "Model":     ["Baseline", "Tuned"],
    "Precision": [round(precision_score(y_test, y_pred_base), 4),
                  round(precision_score(y_test, y_pred_tuned), 4)],
    "Recall":    [round(recall_score(y_test, y_pred_base), 4),
                  round(recall_score(y_test, y_pred_tuned), 4)],
    "F1-Score":  [round(f1_score(y_test, y_pred_base), 4),
                  round(f1_score(y_test, y_pred_tuned), 4)],
})
print(comparison.to_string(index=False))
